{
  "name": "ariadne-worklanes",
  "version": "0.1.0",
  "private": true,
  "description": "Local worklane observability for long-running agent and ops sessions.",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @ariadne-worklanes/core build && pnpm --filter @ariadne-worklanes/dashboard dev",
    "mcp": "pnpm --filter @ariadne-worklanes/mcp-server start",
    "mcp:dev": "pnpm --filter @ariadne-worklanes/mcp-server dev",
    "test": "pnpm build && pnpm -r --if-present test",
    "typecheck": "pnpm --filter @ariadne-worklanes/core build && pnpm -r typecheck"
  },
  "keywords": [
    "agents",
    "mcp",
    "observability",
    "codex",
    "dashboard"
  ],
  "author": "Boris Teoharov",
  "license": "MIT"
}
