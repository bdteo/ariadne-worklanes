{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bdteo/ariadne-worklanes/schemas/worklane.v2.json",
  "title": "Ariadne Worklane v2",
  "type": "object",
  "required": ["schemaVersion", "id", "title", "status", "startedAt", "updatedAt", "staleAfterMinutes", "progress"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "scope": { "type": "string" },
    "owner": { "type": "string" },
    "cwd": { "type": "string" },
    "workspace": { "type": "string" },
    "repo": { "type": "string" },
    "threadId": { "type": "string" },
    "sessionId": { "type": "string" },
    "lastActor": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["planned", "active", "waiting", "blocked", "complete", "cancelled", "archived"]
    },
    "startedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "archivedAt": { "type": "string", "format": "date-time" },
    "staleAfterMinutes": { "type": "number", "exclusiveMinimum": 0 },
    "progress": {
      "type": "object",
      "required": ["current", "total", "unit"],
      "properties": {
        "current": { "type": "number", "minimum": 0 },
        "total": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "type": "string", "minLength": 1 }
      }
    },
    "baseline": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
    "metrics": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
    "milestones": { "type": "array", "items": { "$ref": "#/$defs/milestone" } },
    "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "nextAction": { "type": "string" },
    "blocker": { "type": "string" },
    "links": { "type": "array", "items": { "$ref": "#/$defs/link" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": ["string", "number", "boolean", "null"] },
        "unit": { "type": "string" }
      }
    },
    "link": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 }
      }
    },
    "milestone": {
      "type": "object",
      "required": ["id", "title", "status", "at"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["planned", "active", "waiting", "blocked", "complete", "cancelled"] },
        "at": { "type": "string", "format": "date-time" },
        "summary": { "type": "string" }
      }
    },
    "event": {
      "type": "object",
      "required": ["id", "type", "at", "message"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "at": { "type": "string", "format": "date-time" },
        "title": { "type": "string" },
        "message": { "type": "string", "minLength": 1 },
        "actor": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["id", "label", "url", "kind", "at"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["link", "file", "pr", "issue", "runbook", "log", "screenshot", "other"] },
        "at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
