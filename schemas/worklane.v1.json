{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bdteo/ariadne-worklanes/schemas/worklane.v1.json",
  "title": "Ariadne Worklane",
  "type": "object",
  "required": ["schemaVersion", "id", "title", "status", "startedAt", "updatedAt", "progress"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "scope": { "type": "string" },
    "cwd": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["planned", "active", "waiting", "blocked", "complete", "cancelled"]
    },
    "startedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "progress": {
      "type": "object",
      "required": ["current", "total", "unit"],
      "properties": {
        "current": { "type": "number", "minimum": 0 },
        "total": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "baseline": {
      "type": "array",
      "items": { "$ref": "#/$defs/metric" }
    },
    "metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/metric" }
    },
    "nextAction": { "type": "string" },
    "blocker": { "type": "string" },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/link" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": ["string", "number", "boolean", "null"] },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },
    "link": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
